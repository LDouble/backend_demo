# 复制本文件仅用于了解变量；推荐运行 `make env` 随机生成真实值。
CAMPUS_MYSQL_DATABASE=campus
CAMPUS_MYSQL_USER=campus
CAMPUS_MYSQL_PASSWORD=
CAMPUS_MYSQL_ROOT_PASSWORD=
CAMPUS_REDIS_PASSWORD=
CAMPUS_JWT_SECRET=
CAMPUS_CONFIG_MASTER_KEY=
CAMPUS_ADMIN_USERNAME=admin
CAMPUS_ADMIN_PASSWORD=

# 微信小程序登录
# appid / secret 通过配置中心管理（group=wechat, key=<appid>, encrypted=true），
# 不再从环境变量注入；此处只保留 endpoint / timeout 等非敏感基础设施配置。
CAMPUS_WECHAT_ENDPOINT=https://api.weixin.qq.com
CAMPUS_WECHAT_HTTP_TIMEOUT=3s

# 可选的宿主机端口覆盖
CAMPUS_HTTP_PORT=8080
CAMPUS_MYSQL_PORT=3306
CAMPUS_REDIS_PORT=6379
GOPROXY=https://goproxy.cn,direct
