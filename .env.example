# 复制本文件仅用于了解变量；推荐运行 `make env` 随机生成真实值。
CAMPUS_MYSQL_DATABASE=campus
CAMPUS_MYSQL_USER=campus
CAMPUS_MYSQL_PASSWORD=
CAMPUS_MYSQL_ROOT_PASSWORD=
CAMPUS_REDIS_PASSWORD=
CAMPUS_JWT_SECRET=
CAMPUS_CONFIG_MASTER_KEY=
CAMPUS_ADMIN_USERNAME=admin
CAMPUS_ADMIN_PASSWORD=

# 可选的宿主机端口覆盖
CAMPUS_HTTP_PORT=8080
