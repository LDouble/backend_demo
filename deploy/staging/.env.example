CAMPUS_IMAGE=registry.example.invalid/campus-platform@sha256:REPLACE_ME
CAMPUS_DOMAIN=staging.example.invalid
CAMPUS_MYSQL_DATABASE=campus
CAMPUS_MYSQL_USER=campus
CAMPUS_MYSQL_PASSWORD=REPLACE_ME
CAMPUS_MYSQL_ROOT_PASSWORD=REPLACE_ME
CAMPUS_REDIS_PASSWORD=REPLACE_ME
CAMPUS_JWT_SECRET=REPLACE_WITH_AT_LEAST_32_BYTES
CAMPUS_CONFIG_MASTER_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY
CAMPUS_ADMIN_USERNAME=admin
CAMPUS_ADMIN_PASSWORD=REPLACE_ME
CAMPUS_REDIS_CONFIG_FILE=/absolute/path/to/redis.conf
CAMPUS_REDIS_CA_FILE=/absolute/path/to/ca.crt
CAMPUS_REDIS_SERVER_CERT_FILE=/absolute/path/to/server.crt
CAMPUS_REDIS_SERVER_KEY_FILE=/absolute/path/to/server.key
CAMPUS_REDIS_CLIENT_CERT_FILE=/absolute/path/to/client.crt
CAMPUS_REDIS_CLIENT_KEY_FILE=/absolute/path/to/client.key
