{
  "module": "marketplace",
  "permissions": [
    {
      "name": "marketplace:admin_read",
      "path_pattern": "/api/v1/admin/marketplace/listings",
      "methods": [
        "GET"
      ]
    },
    {
      "name": "marketplace:create",
      "path_pattern": "/api/v1/marketplace/listings",
      "methods": [
        "POST"
      ],
      "default_roles": [
        "member"
      ]
    },
    {
      "name": "marketplace:order_create",
      "path_pattern": "/api/v1/marketplace/orders",
      "methods": [
        "POST"
      ],
      "default_roles": [
        "member"
      ]
    },
    {
      "name": "marketplace:read",
      "path_pattern": "/api/v1/marketplace/listings",
      "methods": [
        "GET"
      ],
      "default_roles": [
        "member"
      ]
    },
    {
      "name": "marketplace:read_item",
      "path_pattern": "/api/v1/marketplace/listings/:id",
      "methods": [
        "GET"
      ],
      "default_roles": [
        "member"
      ]
    },
    {
      "name": "marketplace:read_mine",
      "path_pattern": "/api/v1/marketplace/listings/mine",
      "methods": [
        "GET"
      ],
      "default_roles": [
        "member"
      ]
    },
    {
      "name": "marketplace:remove",
      "path_pattern": "/api/v1/admin/marketplace/listings/:id",
      "methods": [
        "DELETE"
      ]
    },
    {
      "name": "marketplace:review",
      "path_pattern": "/api/v1/admin/marketplace/listings/:id/review",
      "methods": [
        "POST"
      ]
    },
    {
      "name": "marketplace:submit",
      "path_pattern": "/api/v1/marketplace/listings/:id/submit",
      "methods": [
        "POST"
      ],
      "default_roles": [
        "member"
      ]
    },
    {
      "name": "marketplace:update",
      "path_pattern": "/api/v1/marketplace/listings/:id",
      "methods": [
        "PATCH"
      ],
      "default_roles": [
        "member"
      ]
    },
    {
      "name": "marketplace:withdraw",
      "path_pattern": "/api/v1/marketplace/listings/:id/withdraw",
      "methods": [
        "POST"
      ],
      "default_roles": [
        "member"
      ]
    }
  ]
}
