{
  "module": "trade",
  "permissions": [
    {
      "name": "trade:cancel",
      "path_pattern": "/api/v1/orders/:id/cancel",
      "methods": [
        "POST"
      ]
    },
    {
      "name": "trade:complete",
      "path_pattern": "/api/v1/orders/:id/complete",
      "methods": [
        "POST"
      ]
    },
    {
      "name": "trade:read",
      "path_pattern": "/api/v1/orders",
      "methods": [
        "GET"
      ]
    },
    {
      "name": "trade:read_item",
      "path_pattern": "/api/v1/orders/:id",
      "methods": [
        "GET"
      ]
    }
  ]
}
