{
  "module": "carpool",
  "permissions": [
    {
      "name": "carpool:admin_read",
      "path_pattern": "/api/v1/admin/carpool/trips",
      "methods": [
        "GET"
      ]
    },
    {
      "name": "carpool:cancel",
      "path_pattern": "/api/v1/carpool/trips/:id/cancel",
      "methods": [
        "POST"
      ],
      "default_roles": [
        "member"
      ]
    },
    {
      "name": "carpool:create",
      "path_pattern": "/api/v1/carpool/trips",
      "methods": [
        "POST"
      ],
      "default_roles": [
        "member"
      ]
    },
    {
      "name": "carpool:join",
      "path_pattern": "/api/v1/carpool/trips/:id/join",
      "methods": [
        "POST"
      ],
      "default_roles": [
        "member"
      ]
    },
    {
      "name": "carpool:leave",
      "path_pattern": "/api/v1/carpool/trips/:id/leave",
      "methods": [
        "POST"
      ],
      "default_roles": [
        "member"
      ]
    },
    {
      "name": "carpool:read",
      "path_pattern": "/api/v1/carpool/trips",
      "methods": [
        "GET"
      ],
      "default_roles": [
        "guest",
        "member"
      ]
    },
    {
      "name": "carpool:read_item",
      "path_pattern": "/api/v1/carpool/trips/:id",
      "methods": [
        "GET"
      ],
      "default_roles": [
        "guest",
        "member"
      ]
    },
    {
      "name": "carpool:read_mine",
      "path_pattern": "/api/v1/carpool/trips/mine",
      "methods": [
        "GET"
      ],
      "default_roles": [
        "member"
      ]
    },
    {
      "name": "carpool:review",
      "path_pattern": "/api/v1/admin/carpool/trips/:id/review",
      "methods": [
        "POST"
      ]
    },
    {
      "name": "carpool:review_revoke",
      "path_pattern": "/api/v1/admin/carpool/trips/:id/revoke-review",
      "methods": [
        "POST"
      ]
    },
    {
      "name": "carpool:submit_review",
      "path_pattern": "/api/v1/carpool/trips/:id/submit-review",
      "methods": [
        "POST"
      ],
      "default_roles": [
        "member"
      ]
    },
    {
      "name": "carpool:update",
      "path_pattern": "/api/v1/carpool/trips/:id",
      "methods": [
        "PATCH"
      ],
      "default_roles": [
        "member"
      ]
    }
  ]
}
